rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny all
    match /{document=**} {
      allow read, write: if false;
    }

    // User profiles: authenticated users can read their own profile.
    // Writes go exclusively through Cloud Functions (admin SDK) to enforce immutability.
    match /numo_users/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }

    // Sessions and messages: only Cloud Functions (admin SDK) access these.
    match /numo_sessions/{sessionId} {
      allow read, write: if false;
    }

    // Blog posts: public reads, authenticated writes only
    match /posts/{post} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
