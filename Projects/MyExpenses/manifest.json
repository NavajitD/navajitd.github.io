{
  "name": "Expense Tracker",
  "short_name": "Expenses",
  "description": "Track spending fast with clarity",
  "start_url": "./expenses.html",
  "display": "standalone",
  "background_color": "#ffffff",
  "theme_color": "#2563eb",
  "orientation": "portrait",
  "share_target": {
    "action": "./expenses.html",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "share_title",
      "text": "share_text",
      "url": "share_url",
      "files": [
        {
          "name": "share_image",
          "accept": ["image/*"]
        }
      ]
    }
  },
  "icons": [
    {
      "src": "data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><rect width='100' height='100' rx='20' fill='%232563eb'/><text x='50' y='50' dominant-baseline='central' text-anchor='middle' font-size='60'>✦</text></svg>",
      "sizes": "any",
      "type": "image/svg+xml",
      "purpose": "any maskable"
    }
  ]
}
